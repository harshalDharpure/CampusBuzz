# Google Maps JavaScript API key (required)
# Get one at: https://console.cloud.google.com/google/maps-apis/
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_api_key_here

# Supabase (database for buildings - required for admin add/edit)
# Create a project at https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
